rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.toLowerCase() == 'lurambifishgrillke@gmail.com' ||
        request.auth.uid == 'JyJspf6nxoNCQCnXQD5CfcMyg653'
      );
    }

    // Menu: Public read, Admin write
    match /menu/{item} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reviews: Public read/create, Admin moderate
    match /reviews/{review} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Reservations: Public create, Admin read/write
    match /reservations/{res} {
      allow read, write: if true;
    }
  }
}
