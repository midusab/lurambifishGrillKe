rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidReview(data) {
      return data.userName is string && data.userName.size() >= 2 && data.userName.size() <= 100 &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() >= 10 && data.comment.size() <= 1000 &&
             data.createdAt == request.time;
    }

    match /reviews/{reviewId} {
      allow list: if true; // Public can see all (maybe filter for approved on client)
      allow get: if true;
      allow create: if isValidReview(request.resource.data);
      allow update, delete: if false; // Only admin can moderate (not implemented yet)
    }
  }
}
